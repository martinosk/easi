{
  "detected": "2026-04-07",
  "stacks": ["typescript", "go"],
  "frameworks": ["react", "vite", "vitest", "playwright", "chi"],
  "packageManager": "npm",
  "format": [
    {
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".json"],
      "cwd": "frontend",
      "command": ["node_modules/.bin/biome", "format", "--write"]
    },
    {
      "extensions": [".go"],
      "cwd": "backend",
      "command": ["gofmt", "-w"]
    }
  ],
  "lint": [
    {
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".json"],
      "cwd": "frontend",
      "command": ["node_modules/.bin/biome", "check", "--write"]
    },
    {
      "extensions": [".go"],
      "cwd": "backend",
      "command": ["golangci-lint", "run", "--fix"],
      "argMode": "dir"
    }
  ]
}
