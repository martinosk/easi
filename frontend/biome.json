{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!**/dist", "!**/node_modules", "!**/coverage", "!**/test-results"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "useExhaustiveDependencies": "error",
        "noRestrictedElements": {
          "level": "error",
          "options": {
            "elements": {
              "button": "Use Mantine `Button` or `ActionIcon` instead. See spec 168.",
              "input": "Use Mantine `TextInput` / `NumberInput` / `Checkbox` etc. instead. See spec 168.",
              "select": "Use Mantine `Select` or `NativeSelect` instead. See spec 168.",
              "textarea": "Use Mantine `Textarea` instead. See spec 168.",
              "dialog": "Use Mantine `Modal` instead. See spec 168.",
              "fieldset": "Use Mantine `Fieldset` instead. See spec 168.",
              "legend": "Use Mantine layout (`Group`/`Stack`) + `Text` instead. See spec 168."
            }
          }
        }
      },
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "a11y": {
        "noSvgWithoutTitle": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off"
      },
      "nursery": {}
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "overrides": [
    {
      "includes": ["**/components/canvas/**", "**/features/canvas/**", "**/*.test.*", "**/test/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noRestrictedElements": "off"
          }
        }
      }
    }
  ]
}
